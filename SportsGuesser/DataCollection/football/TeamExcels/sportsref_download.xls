<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr class="over_header"> <th aria-label=" " data-stat="header_empty_0" colspan="4" class=" poptip over_header center"></th> <th aria-label=" " data-stat="header_blank" colspan="9" class=" poptip over_header center"></th> <th aria-label="Performance" data-stat="header_performance" colspan="10" class=" poptip over_header center group_start">Performance</th> </tr> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="tooltip ranker poptip sort_default_asc show_partial_when_sorting center" data-tip="&lt;strong&gt;Rank&lt;/strong&gt;&lt;br&gt;This is a count of the rows from top to bottom.&lt;br&gt;It is recalculated following the sorting of a column.">Rk</th> <th aria-label="Season" data-stat="year_id" scope="col" class=" poptip sort_col center" data-tip="Season&lt;br&gt;Winter leagues generally run from August to May of the following year.&lt;br&gt;Summer leagues generally run from February to November of the same year.">Season</th> <th aria-label="Team" data-stat="team_name_abbr" scope="col" class=" poptip sort_default_asc center">Team</th> <th aria-label="Comp" data-stat="comp_name_abbr" scope="col" class=" poptip sort_default_asc center" data-tip="Competition">Comp</th> <th aria-label="MP" data-stat="games" scope="col" class=" poptip center" data-tip="Matches Played by the player or squad">MP</th> <th aria-label="W" data-stat="wins" scope="col" class=" poptip center" data-tip="Wins">W</th> <th aria-label="D" data-stat="ties" scope="col" class=" poptip center" data-tip="Draws">D</th> <th aria-label="L" data-stat="losses" scope="col" class=" poptip center" data-tip="Losses">L</th> <th aria-label="Pts" data-stat="points" scope="col" class=" poptip center" data-tip="Most leagues are ordered by points.&lt;br&gt;Three for a win and one for a draw.">Pts</th> <th aria-label="Pts/MP" data-stat="points_avg" scope="col" class=" poptip center" data-tip="Points per Match Played" data-filter="1" data-name="">Pts/MP</th> <th aria-label="Min" data-stat="minutes" scope="col" class=" poptip center" data-tip="Minutes">Min</th> <th aria-label="Subs" data-stat="games_subs" scope="col" class=" poptip center" data-tip="Games as sub&lt;br&gt;Game or games player did not start, so as a substitute">Subs</th> <th aria-label="LgRank" data-stat="lg_finish" scope="col" class=" poptip sort_default_asc center" data-tip="Squad finish in competition&lt;br&gt;Finish within the league or competition.&lt;br&gt;For knockout competitions may show final round reached.&lt;br&gt;Colors and arrows represent promotion/relegation or qualifiation for continental cups.&lt;br&gt;Trophy indicates team won league whether by playoffs or by leading the table.&lt;br&gt;Star indicates topped table in league USING another means of naming champion.">LgRank</th> <th aria-label="GF" data-stat="goals_for" scope="col" class=" poptip center" data-tip="Goals For">GF</th> <th aria-label="GA" data-stat="goals_against" scope="col" class=" poptip sort_default_asc center" data-tip="Goals Against">GA</th> <th aria-label="GD" data-stat="goal_diff" scope="col" class=" poptip center" data-tip="Goal Difference">GD</th> <th aria-label="Poss" data-stat="possession" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Possession&lt;/strong&gt;&lt;br&gt;Calculated as the percentage of passes attempted" data-filter="1" data-name="">Poss</th> <th aria-label="CS" data-stat="gk_clean_sheets" scope="col" class=" poptip center" data-tip="Clean Sheets&lt;br&gt;Full matches by goalkeeper where no goals are allowed.">CS</th> <th aria-label="CS%" data-stat="clean_sheets_pct" scope=